    {
      "name": "transactions",
      "item": [
        {
          "name": "create transaction",
          "request": {
            "auth": {
              "type": "jwt",
              "jwt": [
                {
                  "key": "algorithm",
                  "value": "HS256",
                  "type": "string"
                },
                {
                  "key": "isSecretBase64Encoded",
                  "value": false,
                  "type": "boolean"
                },
                {
                  "key": "payload",
                  "value": "{}",
                  "type": "string"
                },
                {
                  "key": "addTokenTo",
                  "value": "header",
                  "type": "string"
                },
                {
                  "key": "headerPrefix",
                  "value": "Bearer",
                  "type": "string"
                },
                {
                  "key": "queryParamKey",
                  "value": "token",
                  "type": "string"
                },
                {
                  "key": "header",
                  "value": "{}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{   \"amount\": 6000, \r\n    \"type\": \"INCOME\", \r\n    \"category\": \"Salary\",\r\n    \"date\": \"2026-04-04T11:25:56.931Z\", \r\n    \"notes\": \"Current month salary\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/transaction/new",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "transaction",
                "new"
              ]
            },
            "description": "create a transaction.  \nonly ADMIN can create trasactions  \nrequest body:  \nStartFragment{  \"amount\": number,  \"type\": \"INCOME\" | \"EXPENSE\",  \"category\": \"string\",  \"date\": \"ISO date string\",  \"notes\": \"string (optional)\"}EndFragment"
          },
          "response": []
        },
        {
          "name": "update transaction",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"amount\": 6969,\r\n    \"type\": \"INCOME\",\r\n    \"category\": \"Salary\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/transaction/:id",
              "protocol": "http",
