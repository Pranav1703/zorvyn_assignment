              "path": [
                "transaction",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            },
            "description": "Update transaction using id.\n\nADMIN and ANALYST can update.  \nrequest body:  \n{  \"amount\": number,  \"type\": \"INCOME\" | \"EXPENSE\",  \"category\": \"string\",  \"date\": \"ISO date string\",  \"notes\": \"string\"}"
          },
          "response": []
        },
        {
          "name": "delete transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/transaction/:id",
              "protocol": "http",
